# General
DOMAIN=my.domain.com

# PostgREST
PGRST_OPENAPI_SERVER_PROXY_URI=https://$DOMAIN
PGRST_USER=authenticator
PGRST_PASSWORD=changeme
# see: https://postgrest.org/en/v12/tutorials/tut1.html#step-2-make-a-secret
# echo "jwt-secret = \"$(LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c32)\""
# goto https://jwt.io/ and sign token with header {"alg": "HS256", "typ": "JWT"} and payload {"role": "api_user"}
PGRST_JWT_SECRET=changeme
# => JWT: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYXBpX3VzZXIifQ.<signature>

# Pgadmin
PGADMIN_DEFAULT_EMAIL=admin@host.com
PGADMIN_DEFAULT_PASSWORD=changeme

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres



